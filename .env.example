# Copy to `.env` and fill in. The defaults below match docker-compose.yml.
# IMPORTANT: ADMIN_PASSWORD is REQUIRED in production — leaving it as the
# default `changeme` makes the server log a warning on every start.

# Password the admin (/) login accepts. Set a strong one for any non-local
# deployment.
ADMIN_PASSWORD=changeme

# Port the container listens on; host:container mapping is in docker-compose.yml
PORT=3100

# Where the SQLite DB + uploaded crests + session signing key persist.
# /data is a bind-mounted volume — keep this path in sync with the volumes: block.
DATA_DIR=/data

# Comma-separated origins the Socket.IO server allows. Use the public domain
# (no trailing slash) plus "null" if you embed the overlay in OBS as a local
# file. Leave blank to allow any origin (default in dev).
# CORS_ORIGINS=https://scoreboard.dctraders.co.in
